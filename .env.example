# AgentKit — Variables de entorno
# Copia este archivo como .env y llena tus datos:
#   cp .env.example .env
#
# Claude Code te ayuda a llenar estos valores durante el setup.
# NUNCA subas el archivo .env a GitHub.

# ── Anthropic API ──────────────────────────────────────────
# Obtener en: https://platform.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# ── Proveedor de WhatsApp ──────────────────────────────────
# Opciones: whapi | meta | twilio
WHATSAPP_PROVIDER=whapi

# ── Whapi.cloud (si WHATSAPP_PROVIDER=whapi) ──────────────
# Obtener en: https://whapi.cloud (plan gratis disponible)
WHAPI_TOKEN=

# ── Meta Cloud API (si WHATSAPP_PROVIDER=meta) ────────────
# Configurar en: https://developers.facebook.com
# META_ACCESS_TOKEN=
# META_PHONE_NUMBER_ID=
# META_VERIFY_TOKEN=agentkit-verify

# ── Twilio (si WHATSAPP_PROVIDER=twilio) ──────────────────
# Configurar en: https://twilio.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ── Servidor ──────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ── Seguridad del dashboard ────────────────────────────────
# Protege /api/carritos, /api/metricas, /api/conversaciones, etc.
# Genera un string aleatorio, ej: openssl rand -hex 32
# OBLIGATORIO en producción — sin esto los datos de clientes quedan expuestos
API_KEY=

# ── Shopify webhooks ───────────────────────────────────────
# Secreto para verificar que los webhooks vienen realmente de Shopify
# Obtener en: Shopify Admin → Settings → Notifications → Webhooks
SHOPIFY_WEBHOOK_SECRET=

# ── Base de datos ─────────────────────────────────────────
# Local (SQLite — datos se pierden al redesplegar en Railway):
DATABASE_URL=sqlite+aiosqlite:///./agentkit.db
# Produccion (PostgreSQL en Railway — USAR ESTO EN PRODUCCION):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# En Railway: agrega el plugin "PostgreSQL" y copia la variable DATABASE_URL automática
